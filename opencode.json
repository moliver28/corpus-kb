{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "corpus-kb": {
      "type": "local",
      "description": "Local RAG system — search, ingest, knowledge graph, SQL queries over your code and documents",
      "command": ["corpus-kb", "--transport", "stdio"],
      "environment": {},
      "autoApprove": [
        "search",
        "search_context",
        "search_similar",
        "retrieve_context",
        "list_documents",
        "get_stats",
        "list_versions",
        "list_branches",
        "get_entity_relations",
        "search_graph",
        "sql_query",
        "sql_tables",
        "get_document_tags",
        "get_metadata",
        "query_document_stats",
        "sync_database"
      ]
    }
  },
  "permission": {
    "bash": {
      "git reset --hard *": "deny",
      "git reset --hard": "deny",
      "git push --force *": "deny",
      "git push --force-with-lease *": "deny",
      "git push --force": "deny",
      "git push --force-with-lease": "deny",
      "git clean -fd *": "deny",
      "git clean -fdx *": "deny",
      "git clean -fd": "deny",
      "git clean -fdx": "deny",
      "git filter-branch *": "deny",
      "git filter-branch": "deny",
      "rm -rf *": "ask",
      "rm -rf": "ask",
      "sudo *": "ask",
      "sudo": "ask",
      "del /s /q *": "ask",
      "Remove-Item -Recurse -Force *": "ask"
    }
  }
}
